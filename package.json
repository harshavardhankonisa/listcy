{
  "name": "listcy",
  "description": "Listcy is a platform where you can create, discover, and share useful lists",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "up": "docker compose -f infra/compose/docker-compose.development.yaml up --build",
    "stop": "docker compose -f infra/compose/docker-compose.development.yaml stop",
    "down": "docker compose -f infra/compose/docker-compose.development.yaml down",
    "reset": "docker compose -f infra/compose/docker-compose.development.yaml down -v",
    "prod:up": "docker compose -f infra/compose/docker-compose.production.yaml up --build -d",
    "prod:stop": "docker compose -f infra/compose/docker-compose.production.yaml stop",
    "build": "next build",
    "start": "next start",
    "lint": "docker exec listcy-main npx eslint .",
    "lint:fix": "docker exec listcy-main npx eslint --fix .",
    "format": "docker exec listcy-main npx prettier --write .",
    "format:all": "docker exec listcy-main npx eslint --fix . && docker exec listcy-main npx prettier --write .",
    "db:push": "docker exec -it listcy-main npx drizzle-kit push",
    "db:generate": "docker exec -it listcy-main npx drizzle-kit generate",
    "db:migrate": "docker exec -it listcy-main npx drizzle-kit migrate",
    "db:studio": "docker exec -it listcy-main npx drizzle-kit studio --host 0.0.0.0",
    "auth:schema": "docker exec listcy-main npx auth@latest generate --config src/api/config/auth.ts --output src/api/schemas/auth.schema.ts --yes",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1032.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1032.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/client-secrets-manager": "^3.1032.0",
    "@aws-sdk/client-sesv2": "^3.1032.0",
    "@aws-sdk/client-sqs": "^3.1032.0",
    "@aws-sdk/credential-providers": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=24.13.0",
    "npm": ">=11.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yaml,yml}": "prettier --write"
  }
}
