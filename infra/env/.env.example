DATABASE_URL=postgresql://listcy:listcy@postgres:5432/listcydb
DATABASE_POOL_MAX=20

ORIGIN="http://localhost:3000"

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET="Xt73eo/qC5exRxpW9BZLVqlMNIEwKwxJulAFb/sYC6Y="
# GitHub OAuth
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# AWS
# LocalStack credentials — "test"/"test" is the expected value for all local calls.
# In production these are provided by the ECS task role; do NOT set them in prod env.
# https://docs.localstack.cloud/references/credentials/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Redirect all AWS SDK calls to LocalStack when set.
# Remove this line entirely for production — the SDK will hit real AWS.
# https://docs.aws.amazon.com/sdkref/latest/guide/settings-global.html#endpoint-url
AWS_ENDPOINT_URL=http://localstack:4566

# S3 — bucket name created by infra/localstack/init/01-buckets.sh locally
# and infra/terraform/s3.tf in production
S3_BUCKET=listcy-avatars

# SQS — LocalStack account ID is always 000000000000 (twelve zeros)
# In production these come from Secrets Manager (see infra/terraform/secrets.tf)
SQS_IMAGE_PROCESSING_URL=http://localstack:4566/000000000000/listcy-image-processing
SQS_EMAIL_NOTIFICATIONS_URL=http://localstack:4566/000000000000/listcy-email-notifications

# SES — must be a verified identity (see infra/localstack/init/04-ses.sh)
SES_FROM_EMAIL=noreply@listcy.com
